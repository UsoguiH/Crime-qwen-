# ══════════════════════════════════════════════════════════════
#  أثر / Athar — Crime Scene AI Analysis — configuration
#  Copy to .env and adjust. Every value has a safe default:
#  with no .env at all the system boots in MOCK mode (no API key,
#  no GPU) and the full pipeline works on the bundled samples.
# ══════════════════════════════════════════════════════════════

# ── Model access ──────────────────────────────────────────────
MODEL_MODE=mock                      # api | local | mock
MODEL_PROVIDER=openrouter            # openrouter | dashscope | custom   (used when MODEL_MODE=api)
OPENAI_BASE_URL=                     # empty = provider preset: openrouter → https://openrouter.ai/api/v1
                                     #                          dashscope → https://dashscope-intl.aliyuncs.com/compatible-mode/v1
OPENAI_API_KEY=                      # OpenRouter or DashScope key
MODEL_NAME_FAST=qwen/qwen3-vl-235b-a22b-instruct      # triage/detection (cheaper: qwen/qwen3-vl-30b-a3b-instruct)
MODEL_NAME_THINKING=qwen/qwen3-vl-235b-a22b-thinking  # aggregation/comparison/narratives
OPENROUTER_DATA_COLLECTION=deny      # privacy routing: only providers that do not collect user data
OPENROUTER_ZDR=false                 # true = strict zero-data-retention routing (may shrink provider pool)
OPENROUTER_PROVIDER_ORDER=           # optional comma-separated provider pin, e.g. "alibaba,deepinfra"
MODEL_MAX_CONCURRENCY=3
MODEL_TIMEOUT_S=180
MODEL_MAX_CALLS_PER_RUN=400          # budget guard — run pauses (resumable) at the cap
RECORD_FIXTURES=0                    # dev: 1 = save live API responses as mock fixtures

# local mode (vLLM ≥ 0.11, OpenAI-compatible, docker compose --profile gpu)
VLLM_BASE_URL=http://vllm:8000/v1
VLLM_MODEL=Qwen/Qwen3-VL-8B-Instruct

# ── Storage / DB ──────────────────────────────────────────────
DATABASE_URL=                        # empty = SQLite at {DATA_DIR}/app.db
                                     # postgres profile: postgresql+asyncpg://athar:athar@postgres/athar
DATA_DIR=/data                       # inside the container (compose mounts the athar-data volume)
MAX_UPLOAD_MB=2048

# ── Pipeline thresholds ───────────────────────────────────────
CONFIDENCE_REVIEW_THRESHOLD=0.75     # below ⇒ «يتطلب مراجعة بشرية»
TRIAGE_RELEVANCE_THRESHOLD=0.35
KEYFRAME_MIN_INTERVAL_S=5
PHASH_DEDUP_DISTANCE=6
IOU_MERGE_THRESHOLD=0.5
MOVE_CENTROID_THRESHOLD=0.15
FACE_BLUR_DEFAULT=true
REPORT_PDF_VARIANT=pdf/a-3u          # falls back to pdf/a-3b if 3u fails validation (WeasyPrint #2841)

# ── App ───────────────────────────────────────────────────────
SECRET_KEY=change-me-please-64-hex
APP_ENV=dev                          # dev | prod
LOG_LEVEL=info
